<?xml version="1.0" encoding="UTF-8"?>
<!-- Destination: Mooney-M20M/FDM/Mooney-M20M.xml -->
<!-- Minimal JSBSim placeholder config: NO external Systems/Engines/Props includes.
     Purpose: allow FlightGear to load the aircraft without quitting at splash. -->

<fdm_config version="2.0" release="ALPHA">
    <fileheader>
        <author>Philips</author>
        <description>Mooney M20M Bravo - minimal placeholder FDM for load stability.</description>
        <note>
            This file intentionally contains only metrics and mass_balance.
            Add aerodynamics/controls/gear/propulsion later, incrementally.
        </note>
    </fileheader>

    <!-- Basic geometry. Values are placeholders; they just need to exist. -->
    <metrics file="FDM/Config/MooneyM20M-metrics" />
    <aerodynamics file="FDM/Config/MooneyM20M-aerodynamics" />
    <ground_reactions file="FDM/Config/MooneyM20M-ground-reactions" />

    <!-- Mass & inertia. These placeholders keep JSBSim happy. -->
    <mass_balance>
        <emptywt unit="LBS">2200</emptywt>

        <!-- Reference point / CG; keep it simple. -->
        <location name="CG" unit="FT">
            <x>0.0</x>
            <y>0.0</y>
            <z>0.0</z>
        </location>

        <!-- Inertia tensor about CG. Non-zero values are important. -->
        <ixx unit="SLUG*FT2">1400</ixx>
        <iyy unit="SLUG*FT2">2200</iyy>
        <izz unit="SLUG*FT2">3200</izz>
        <ixy unit="SLUG*FT2">0</ixy>
        <ixz unit="SLUG*FT2">0</ixz>
        <iyz unit="SLUG*FT2">0</iyz>
    </mass_balance>

</fdm_config>