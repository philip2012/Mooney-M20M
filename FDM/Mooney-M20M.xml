<?xml version="1.0" encoding="UTF-8"?>
<!-- Destination: Mooney-M20M/FDM/Mooney-M20M.xml -->
<!-- Minimal JSBSim placeholder config: NO external Systems/Engines/Props includes.
     Purpose: allow FlightGear to load the aircraft without quitting at splash. -->

<fdm_config version="2.0" release="ALPHA">
    <fileheader>
        <author>Philips</author>
        <description>Mooney M20M Bravo - minimal placeholder FDM for load stability.</description>
        <note>
            This file intentionally contains only metrics and mass_balance.
            Add aerodynamics/controls/gear/propulsion later, incrementally.
        </note>
    </fileheader>

    <!-- Basic geometry. Values are placeholders; they just need to exist. -->
    <metrics>
        <wingarea unit="FT2">175</wingarea>
        <wingspan unit="FT">36.0</wingspan>
        <chord unit="FT">4.9</chord>

        <htailarea unit="FT2">30</htailarea>
        <htailarm unit="FT">12</htailarm>

        <vtailarea unit="FT2">18</vtailarea>
        <vtailarm unit="FT">11</vtailarm>
    </metrics>

    <!-- Mass & inertia. These placeholders keep JSBSim happy. -->
    <mass_balance>
        <emptywt unit="LBS">2200</emptywt>

        <!-- Reference point / CG; keep it simple. -->
        <location name="CG" unit="FT">
            <x>0.0</x>
            <y>0.0</y>
            <z>0.0</z>
        </location>

        <!-- Inertia tensor about CG. Non-zero values are important. -->
        <ixx unit="SLUG*FT2">1400</ixx>
        <iyy unit="SLUG*FT2">2200</iyy>
        <izz unit="SLUG*FT2">3200</izz>
        <ixy unit="SLUG*FT2">0</ixy>
        <ixz unit="SLUG*FT2">0</ixz>
        <iyz unit="SLUG*FT2">0</iyz>
    </mass_balance>

    <!-- No propulsion, no aerodynamics, no controls, no gear.
       JSBSim will still initialize; FG should load the aircraft. -->

    <!-- Add this inside <fdm_config> ... </fdm_config> -->
    <ground_reactions>
        <contact type="BOGEY" name="nose">
            <location unit="FT">
                <x>6.0</x>
                <y>0.0</y>
                <z>-2.5</z>
            </location>
            <static_friction>0.8</static_friction>
            <dynamic_friction>0.6</dynamic_friction>
            <spring_coeff unit="LBS/FT">20000</spring_coeff>
            <damping_coeff unit="LBS/FT/SEC">3000</damping_coeff>
            <max_steer unit="DEG">30</max_steer>
        </contact>

        <contact type="BOGEY" name="left-main">
            <location unit="FT">
                <x>-1.0</x>
                <y>-4.0</y>
                <z>-3.0</z>
            </location>
            <static_friction>0.8</static_friction>
            <dynamic_friction>0.6</dynamic_friction>
            <spring_coeff unit="LBS/FT">35000</spring_coeff>
            <damping_coeff unit="LBS/FT/SEC">5000</damping_coeff>
        </contact>

        <contact type="BOGEY" name="right-main">
            <location unit="FT">
                <x>-1.0</x>
                <y>4.0</y>
                <z>-3.0</z>
            </location>
            <static_friction>0.8</static_friction>
            <dynamic_friction>0.6</dynamic_friction>
            <spring_coeff unit="LBS/FT">35000</spring_coeff>
            <damping_coeff unit="LBS/FT/SEC">5000</damping_coeff>
        </contact>
    </ground_reactions>

    <aerodynamics>
        <!-- Minimal valid JSBSim aero: Lift/Side/Drag + Roll/Pitch/Yaw axes
         Using zero functions just to pass loader and spawn. -->

        <axis name="DRAG">
            <function name="aero/drag-lbs">
                <value>0</value>
            </function>
        </axis>

        <axis name="SIDE">
            <function name="aero/side-lbs">
                <value>0</value>
            </function>
        </axis>

        <axis name="LIFT">
            <function name="aero/lift-lbs">
                <value>0</value>
            </function>
        </axis>

        <axis name="ROLL">
            <function name="aero/roll-lbsft">
                <value>0</value>
            </function>
        </axis>

        <axis name="PITCH">
            <function name="aero/pitch-lbsft">
                <value>0</value>
            </function>
        </axis>

        <axis name="YAW">
            <function name="aero/yaw-lbsft">
                <value>0</value>
            </function>
        </axis>
    </aerodynamics>
</fdm_config>