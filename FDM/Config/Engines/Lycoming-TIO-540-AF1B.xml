<?xml version="1.0" encoding="UTF-8"?>

<piston_engine name="Lycoming TIO-540-AF1B">
    <!-- Mooney M20M Bravo / AOPA-confirmed baseline -->
    <minmp unit="INHG">10.0</minmp>
    <maxmp unit="INHG">38.0</maxmp>

    <idlerpm>700</idlerpm>
    <maxrpm>2575</maxrpm>
    <maxhp unit="HP">270</maxhp>

    <displacement unit="IN3">541.5</displacement>
    <cycles>4</cycles>
    <cylinders>6</cylinders>

    <!-- These still need exact Lycoming data if you want type-accurate engine behavior -->
    <compression-ratio>8.0</compression-ratio>
    <sparkfaildrop>0.08</sparkfaildrop>
    <static-friction unit="HP">6.0</static-friction>

    <air-intake-impedance-factor>1.0</air-intake-impedance-factor>
    <ram-air-factor>0.2</ram-air-factor>
    <cooling-factor>1.0</cooling-factor>
    <man-press-lag>0.2</man-press-lag>

    <starter-torque>120.0</starter-torque>
    <starter-rpm>900.0</starter-rpm>

    <bsfc unit="LBS/HP*HR">0.45</bsfc>
    <volumetric-efficiency>0.90</volumetric-efficiency>

    <!-- Simple boosted-engine starter model -->
    <numboostspeeds>1</numboostspeeds>
    <boostoverride>1</boostoverride>
    <boostmanual>0</boostmanual>
    <boost-loss-factor>1.16</boost-loss-factor>

    <!-- Starter turbo assumptions: tune later from POH/manifold-pressure behavior -->
    <ratedboost1 unit="INHG">38.0</ratedboost1>
    <ratedrpm1>2575</ratedrpm1>
    <ratedaltitude1 unit="FT">20000</ratedaltitude1>
    <takeoffboost unit="INHG">38.0</takeoffboost>
</piston_engine>