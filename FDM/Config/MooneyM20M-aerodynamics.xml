<?xml version="1.0" encoding="UTF-8"?>

<aerodynamics>
    <!-- Minimal valid JSBSim aero: Lift/Side/Drag + Roll/Pitch/Yaw axes
         Using zero functions just to pass loader and spawn. -->

    <axis name="DRAG">
        <function name="aero/drag-lbs">
            <value>0</value>
        </function>
    </axis>

    <axis name="SIDE">
        <function name="aero/side-lbs">
            <value>0</value>
        </function>
    </axis>

    <axis name="LIFT">
        <function name="aero/lift-lbs">
            <value>0</value>
        </function>
    </axis>

    <axis name="ROLL">
        <function name="aero/roll-lbsft">
            <value>0</value>
        </function>
    </axis>

    <axis name="PITCH">
        <function name="aero/pitch-lbsft">
            <value>0</value>
        </function>
    </axis>

    <axis name="YAW">
        <function name="aero/yaw-lbsft">
            <value>0</value>
        </function>
    </axis>
</aerodynamics>