<?xml version="1.0" encoding="UTF-8"?>

<!--
    Mooney M20M Bravo starter propeller file for JSBSim.

    What is real:
    - 3 blades
    - constant-speed prop
    - 75 inch diameter

    What is still estimated:
    - min/max blade pitch
    - Ct/Cp tables
    - coefficient scaling
-->

<propeller name="M20M Starter Propeller" version="1.1">

    <!-- Prop rotational inertia -->
    <!-- Starter estimate: tune later if engine spool/governor feel is off -->
    <ixx unit="SLUG*FT2">2.15</ixx>

    <!-- AOPA Bravo review lists 75-inch diameter, 3-blade, constant-speed -->
    <diameter unit="IN">75.0</diameter>
    <numblades>3</numblades>

    <!-- Direct-drive piston setup -->
    <gearratio>1.0</gearratio>

    <!-- Starter blade-angle assumptions for a constant-speed GA prop -->
    <minpitch>15.1</minpitch>
    <maxpitch>43.0</maxpitch>

    <!-- Match engine/governor operating envelope -->
    <minrpm>700.0</minrpm>
    <maxrpm>2575</maxrpm>

    <!-- Constant-speed governor enabled -->
    <constspeed>1</constspeed>

    <!-- No reverse on this aircraft -->
    <reversepitch>0.0</reversepitch>

    <!-- Leave neutral for now; tune only if needed -->
    <ct_factor>1.0</ct_factor>
    <cp_factor>1.0</cp_factor>

    <!--
        C_THRUST and C_POWER are starter generic curves vs advance ratio J.
        These are estimated, not Hartzell/Mooney manufacturer tables.
        Shape is chosen to be plausible for a 3-blade constant-speed piston prop.
    -->

    <table name="C_THRUST" type="internal">
        <tableData>
            0.0 0.110
            0.2 0.108
            0.4 0.103
            0.6 0.094
            0.8 0.082
            1.0 0.068
            1.2 0.053
            1.4 0.038
            1.6 0.024
            1.8 0.012
            2.0 0.000
            2.2 -0.008
        </tableData>
    </table>

    <table name="C_POWER" type="internal">
        <tableData>
            0.0 0.060
            0.2 0.061
            0.4 0.062
            0.6 0.061
            0.8 0.058
            1.0 0.053
            1.2 0.046
            1.4 0.038
            1.6 0.029
            1.8 0.020
            2.0 0.012
            2.2 0.006
        </tableData>
    </table>

    <!--
        Optional Mach correction tables.
        Keep neutral initially so they do not distort early tuning.
        You can remove them entirely if you want even simpler behavior.
    -->
    <table name="CT_MACH" type="internal">
        <tableData>
            0.0 1.00
            0.5 1.00
            0.7 0.99
            0.8 0.97
            0.9 0.93
            1.0 0.88
            1.1 0.80
        </tableData>
    </table>

    <table name="CP_MACH" type="internal">
        <tableData>
            0.0 1.00
            0.5 1.00
            0.7 1.01
            0.8 1.03
            0.9 1.06
            1.0 1.10
            1.1 1.16
        </tableData>
    </table>

</propeller>